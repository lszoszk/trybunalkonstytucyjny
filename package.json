{
  "name": "trybunalkonstytucyjny",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape:ipo": "node scripts/scrape_ipo_decisions.mjs",
    "fetch:ipo-bench-map": "node scripts/fetch_ipo_bench_map.mjs",
    "enrich:proceeding-intro": "node scripts/enrich_proceeding_intro.mjs",
    "build:dashboard": "node scripts/build_tk_dashboard_data.mjs --input output/playwright/tk-all.decisions.json --force_no_inne true",
    "build:similarity": "node scripts/build_case_similarity.mjs --input docs/data/tk_cases.jsonl --outdir docs/data --sample50 docs/data/tk_cases_sample50.jsonl --sample200 docs/data/tk_cases_sample200.jsonl",
    "build:lemma-shards:full-bench": "python3 scripts/build_lemma_shards.py --input docs/data/tk_cases_full_bench.jsonl --outdir docs/data/lemma_shards --dataset-key full_bench",
    "build:lemma-shards:sample200": "python3 scripts/build_lemma_shards.py --input docs/data/tk_cases_sample200.jsonl --outdir docs/data/lemma_shards --dataset-key sample200",
    "build:lemma-shards:all": "npm run build:lemma-shards:full-bench && npm run build:lemma-shards:sample200",
    "build:all": "npm run build:dashboard && npm run build:similarity",
    "preview:docs": "python3 -m http.server 4173 --directory docs"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  }
}
